 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# Toronto Rent Affordability Index — 2019 to March 2026\n", "**Author:** Aishwarya Senthil\n", "**Question:** How many months of income does a Toronto renter need to cover one month of rent — and how has that changed?"]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 1 — Install & Import"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run this first — installs anything missing\n",
    "# !pip install pandas openpyxl plotly kaleido\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "import os, warnings\n",
    "warnings.filterwarnings(\'ignore\')\n",
    "\n",
    "os.makedirs(\'data/processed\', exist_ok=True)\n",
    "os.makedirs(\'visuals\', exist_ok=True)\n",
    "\n",
    "BEDROOM_TYPES = [\'Bachelor\', \'1 Bedroom\', \'2 Bedroom\', \'3 Bedroom +\']\n",
    "COLORS = {\'Bachelor\':\'#7F77DD\', \'1 Bedroom\':\'#1D9E75\', \'2 Bedroom\':\'#BA7517\', \'3 Bedroom +\':\'#D85A30\', \'Total\':\'#378ADD\'}\n",
    "print(\'Setup complete.\')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 2 — Load CMHC Files\n", "Each file has 2 years. We always take the NEWER year (right column) from each file to avoid duplicates.\n", "- rmr-toronto-2019.xlsx → take Oct-19\n", "- rmr-toronto-2020.xlsx → take Oct-20\n", "- rmr-toronto-2021.xlsx → take Oct-21\n", "- rmr-toronto-2022.xlsx → take Oct-22\n", "- rmr-toronto-2023.xlsx → take Oct-23\n", "- rmr-toronto-2024.xlsx → take Oct-24\n", "- rmr-toronto-2025.xlsx → take Oct-25\n", "\n", "**Plus from rmr-toronto-2019.xlsx we also take Oct-18 (the older column) to get 2018 data.**"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_value(val):\n",
    "    \'\'\'Convert CMHC cell values to float. Handles **, letters a/b/c/d, arrows.\'\'\'\n",
    "    if pd.isna(val): return np.nan\n",
    "    s = str(val).strip()\n",
    "    if s in [\'**\', \'++\', \'--\', \'\']: return np.nan\n",
    "    # Remove trailing letters (a, b, c, d = data quality flags) and arrows\n",
    "    import re\n",
    "    s = re.sub(r\'[abcd↑↓\\-]+$\', \'\', s.strip())\n",
    "    s = s.replace(\',\', \'\').strip()\n",
    "    try: return float(s)\n",
    "    except: return np.nan\n",
    "\n",
    "def load_cmhc_sheet(filepath, sheet_name, year, take_col=\'newer\'):\n",
    "    \'\'\'\n",
    "    Load one sheet from a CMHC Excel file.\n",
    "    take_col: \'newer\' = take the right/newer year column per bedroom type\n",
    "              \'older\' = take the left/older year column (only used for 2018 from the 2019 file)\n",
    "    Returns a DataFrame with columns: zone, bedroom_type, value\n",
    "    \'\'\'\n",
    "    # Read raw — skip title rows, no header\n",
    "    raw = pd.read_excel(filepath, sheet_name=sheet_name, header=None)\n",
    "    \n",
    "    # Find the header row — it contains \'Zone\' in column A\n",
    "    header_row = None\n",
    "    for i, row in raw.iterrows():\n",
    "        if str(row.iloc[0]).strip().lower() == \'zone\':\n",
    "            header_row = i\n",
    "            break\n",
    "    \n",
    "    if header_row is None:\n",
    "        print(f\'  WARNING: Could not find header row in {filepath} {sheet_name}\')\n",
    "        return pd.DataFrame()\n",
    "    \n",
    "    # The row above header_row has bedroom type labels (Bachelor, 1 Bedroom etc.)\n",
    "    # The header_row itself has Oct-XX, Oct-XX repeating\n",
    "    bedroom_row = raw.iloc[header_row - 2]  # bedroom type labels\n",
    "    month_row   = raw.iloc[header_row]       # Oct-XX labels\n",
    "    \n",
    "    # Build column map: col_index -> (bedroom_type, year_label)\n",
    "    col_map = {}\n",
    "    current_btype = None\n",
    "    for col_idx in range(1, len(month_row)):\n",
    "        btype_val = str(bedroom_row.iloc[col_idx]).strip()\n",
    "        if btype_val not in [\'nan\', \'\'] and any(b in btype_val for b in [\'Bachelor\',\'1 Bed\',\'2 Bed\',\'3 Bed\',\'Total\']):\n",
    "            current_btype = btype_val\n",
    "            # Normalise name\n",
    "            if \'Bachelor\' in current_btype: current_btype = \'Bachelor\'\n",
    "            elif \'1 Bed\' in current_btype: current_btype = \'1 Bedroom\'\n",
    "            elif \'2 Bed\' in current_btype: current_btype = \'2 Bedroom\'\n",
    "            elif \'3 Bed\' in current_btype: current_btype = \'3 Bedroom +\'\n",
    "            elif \'Total\' in current_btype: current_btype = \'Total\'\n",
    "        month_val = str(month_row.iloc[col_idx]).strip()\n",
    "        if current_btype and \'Oct\' in month_val:\n",
    "            col_map[col_idx] = (current_btype, month_val)\n",
    "    \n",
    "    # Data rows start after header_row + 1\n",
    "    data = raw.iloc[header_row + 1:].copy()\n",
    "    data = data.reset_index(drop=True)\n",
    "    \n",
    "    records = []\n",
    "    for _, row in data.iterrows():\n",
    "        zone = str(row.iloc[0]).strip()\n",
    "        if not zone or zone == \'nan\' or zone.startswith(\'Note\') or zone.startswith(\'Source\'): continue\n",
    "        \n",
    "        # Group columns by bedroom type, pick older or newer year\n",
    "        btype_cols = {}\n",
    "        for col_idx, (btype, month_lbl) in col_map.items():\n",
    "            if btype not in btype_cols:\n",
    "                btype_cols[btype] = []\n",
    "            btype_cols[btype].append((col_idx, month_lbl))\n",
    "        \n",
    "        for btype, col_list in btype_cols.items():\n",
    "            if btype == \'Total\': continue  # skip Total column\n",
    "            if btype not in BEDROOM_TYPES: continue\n",
    "            # Sort by month label to identify older vs newer\n",
    "            col_list_sorted = sorted(col_list, key=lambda x: x[1])\n",
    "            target_col = col_list_sorted[0] if take_col == \'older\' else col_list_sorted[-1]\n",
    "            val = clean_value(row.iloc[target_col[0]])\n",
    "            records.append({\'year\': year, \'zone\': zone, \'bedroom_type\': btype, \'value\': val})\n",
    "    \n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "print(\'Functions defined.\')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load all CMHC files ──────────────────────────────────────────────────────\n",
    "CMHC_DIR = \'data/cmhc/\'\n",
    "\n",
    "# File list: (filename, year_to_extract, take_col)\n",
    "cmhc_files = [\n",
    "    (\'rmr-toronto-2019.xlsx\', 2018, \'older\'),   # Oct-18 from 2019 file\n",
    "    (\'rmr-toronto-2019.xlsx\', 2019, \'newer\'),   # Oct-19 from 2019 file\n",
    "    (\'rmr-toronto-2020.xlsx\', 2020, \'newer\'),\n",
    "    (\'rmr-toronto-2021.xlsx\', 2021, \'newer\'),\n",
    "    (\'rmr-toronto-2022.xlsx\', 2022, \'newer\'),\n",
    "    (\'rmr-toronto-2023.xlsx\', 2023, \'newer\'),\n",
    "    (\'rmr-toronto-2024.xlsx\', 2024, \'newer\'),\n",
    "    (\'rmr-toronto-2025.xlsx\', 2025, \'newer\'),\n",
    "]\n",
    "\n",
    "rent_frames, vacancy_frames = [], []\n",
    "\n",
    "for fname, year, take_col in cmhc_files:\n",
    "    fpath = os.path.join(CMHC_DIR, fname)\n",
    "    if not os.path.exists(fpath):\n",
    "        print(f\'  MISSING: {fpath}\')\n",
    "        continue\n",
    "    print(f\'Loading {fname} → year {year}...\')\n",
    "    \n",
    "    rent_df = load_cmhc_sheet(fpath, \'Table 1.1.2\', year, take_col)\n",
    "    rent_df[\'metric\'] = \'avg_rent\'\n",
    "    rent_frames.append(rent_df)\n",
    "    \n",
    "    vac_df = load_cmhc_sheet(fpath, \'Table 1.1.1\', year, take_col)\n",
    "    vac_df[\'metric\'] = \'vacancy_rate\'\n",
    "    vacancy_frames.append(vac_df)\n",
    "\n",
    "rent_raw    = pd.concat(rent_frames,    ignore_index=True)\n",
    "vacancy_raw = pd.concat(vacancy_frames, ignore_index=True)\n",
    "\n",
    "print(f\'\\nRent rows loaded:    {len(rent_raw)}\')\n",
    "print(f\'Vacancy rows loaded: {len(vacancy_raw)}\')\n",
    "print(f\'Years in rent data:  {sorted(rent_raw.year.unique())}\')\n",
    "print(\'\\nSample:\')\n",
    "print(rent_raw[rent_raw.zone.str.contains(\'Toronto\', na=False)].head(12))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 3 — Extract Toronto CMA Level (not zone level)\n", "We want the whole-city Toronto CMA row, not individual zones, for our time series."]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# The CMA-level row is usually labelled \'Toronto CMA\' or \'Toronto (Zones 1-17)\'\n",
    "# Let\'s check what zone names exist\n",
    "print(\'All zone names in rent data:\')\n",
    "for z in sorted(rent_raw.zone.unique()):\n",
    "    print(\'  \', z)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── After running the cell above, find the Toronto CMA row name ──────────────\n",
    "# Common names: \'Toronto\', \'Toronto CMA\', \'Toronto (Zones 1-17)\'\n",
    "# Update CMA_LABEL below to match exactly what you see printed above\n",
    "\n",
    "CMA_LABEL = \'Toronto (Zones 1-17)\'  # <-- UPDATE THIS if different\n",
    "\n",
    "rent_cma = rent_raw[rent_raw[\'zone\'] == CMA_LABEL].copy()\n",
    "vac_cma  = vacancy_raw[vacancy_raw[\'zone\'] == CMA_LABEL].copy()\n",
    "\n",
    "print(f\'CMA rent rows: {len(rent_cma)}\')\n",
    "print(rent_cma.pivot_table(values=\'value\', index=\'year\', columns=\'bedroom_type\').round(0))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 4 — Load StatCan Income Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "inc_raw = pd.read_csv(\'data/statcan/statcan_income.csv\', skiprows=6, encoding=\'latin1\')\n",
    "print(\'Income CSV columns:\', inc_raw.columns.tolist())\n",
    "print(inc_raw.head(8))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# After reviewing columns above, extract the after-tax income for single persons\n",
    "# The CSV from StatCan typically has columns: REF_DATE, GEO, DGUID, Economic family type, \n",
    "#   Income concept, UOM, UOM_ID, SCALAR_FACTOR, SCALAR_ID, VECTOR, COORDINATE, VALUE, STATUS, SYMBOL, TERMINATED, DECIMALS\n",
    "\n",
    "# Filter to: persons not in economic family + median after-tax income\n",
    "income_df = inc_raw[\n",
    "    (inc_raw.iloc[:, 3].str.contains(\'Persons not in an economic family\', na=False)) &\n",
    "    (inc_raw.iloc[:, 4].str.contains(\'Median after-tax income\', na=False))\n",
    "].copy()\n",
    "\n",
    "income_df = income_df.rename(columns={income_df.columns[0]: \'year\', income_df.columns[-6]: \'median_income\'})\n",
    "income_df[\'year\'] = income_df[\'year\'].astype(int)\n",
    "income_df[\'median_income\'] = pd.to_numeric(income_df[\'median_income\'], errors=\'coerce\')\n",
    "income_df = income_df[[\'year\', \'median_income\']].dropna().sort_values(\'year\')\n",
    "\n",
    "# Add 2024 and 2025 estimates using LFS wage growth proxy (+3.5% per year)\n",
    "last_val = income_df.loc[income_df[\'year\'] == income_df[\'year\'].max(), \'median_income\'].values[0]\n",
    "for yr, mult in [(2024, 1.035), (2025, 1.035**2), (2026, 1.035**2.5)]:\n",
    "    income_df = pd.concat([income_df, pd.DataFrame([{\'year\': yr, \'median_income\': round(last_val * mult)}])], ignore_index=True)\n",
    "\n",
    "income_df[\'income_source\'] = income_df[\'year\'].apply(lambda y: \'StatCan CIS\' if y <= 2023 else \'LFS proxy estimate\')\n",
    "income_df[\'monthly_income\'] = (income_df[\'median_income\'] / 12).round(0)\n",
    "\n",
    "print(\'Income data (Toronto CMA, single persons, after-tax):\')\n",
    "print(income_df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 5 — Load CPI Data"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cpi_raw = pd.read_csv(\'data/statcan/statcan_cpi_rent.csv\', skiprows=6, encoding=\'latin1\')\n",
    "print(\'CPI columns:\', cpi_raw.columns.tolist())\n",
    "print(cpi_raw.head(5))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# CPI file has monthly data, wide format (months as columns) or long format\n",
    "# Check if it\'s wide or long by looking at shape\n",
    "print(f\'Shape: {cpi_raw.shape}\')\n",
    "\n",
    "# If long format (many rows): columns are REF_DATE, GEO, Products and product groups, VALUE\n",
    "# Filter to \'Rented accommodation\'\n",
    "cpi_rented = cpi_raw[cpi_raw.iloc[:, 2].str.contains(\'Rented accommodation\', na=False)].copy()\n",
    "cpi_rented = cpi_rented.rename(columns={cpi_rented.columns[0]: \'ref_date\', cpi_rented.columns[-6]: \'cpi_value\'})\n",
    "cpi_rented[\'cpi_value\'] = pd.to_numeric(cpi_rented[\'cpi_value\'], errors=\'coerce\')\n",
    "\n",
    "# Parse year from ref_date (format: YYYY-MM)\n",
    "cpi_rented[\'year\'] = cpi_rented[\'ref_date\'].str[:4].astype(int)\n",
    "\n",
    "# Annual average\n",
    "cpi_annual = cpi_rented.groupby(\'year\')[\'cpi_value\'].mean().reset_index()\n",
    "cpi_annual.columns = [\'year\', \'cpi_index\']\n",
    "\n",
    "# Base year = 2019 (set to 100)\n",
    "base = cpi_annual.loc[cpi_annual[\'year\'] == 2019, \'cpi_index\'].values[0]\n",
    "cpi_annual[\'cpi_deflator\'] = (base / cpi_annual[\'cpi_index\']).round(4)\n",
    "\n",
    "print(\'CPI deflators (base = 2019):\')\n",
    "print(cpi_annual[cpi_annual[\'year\'] >= 2018].to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 6 — Load 2026 Bridge Data (Rentals.ca)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load from the spreadsheet you already have\n",
    "bridge_raw = pd.read_excel(\'data/manual/rentals_ca_2026.xlsx\', sheet_name=\'Annual Avg — Use In Notebook\', skiprows=2)\n",
    "print(\'Bridge columns:\', bridge_raw.columns.tolist())\n",
    "print(bridge_raw)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rename columns to match our schema\n",
    "# Expected: Year | Bedroom Type | Jan 2026 | Feb 2026 | Mar 2026 | Avg Q1 2026 | CMHC Name\n",
    "bridge_raw.columns = [\'year\', \'bedroom_type\', \'jan\', \'feb\', \'mar\', \'avg_rent\', \'cmhc_name\']\n",
    "bridge_raw = bridge_raw.dropna(subset=[\'bedroom_type\']).copy()\n",
    "bridge_raw[\'year\'] = 2026\n",
    "bridge_raw[\'zone\'] = \'Toronto (Zones 1-17)\'  # match CMA_LABEL\n",
    "bridge_raw[\'metric\'] = \'avg_rent\'\n",
    "bridge_raw[\'bedroom_type\'] = bridge_raw[\'bedroom_type\'].replace({\'Studio\': \'Bachelor\'})\n",
    "bridge_raw[\'data_source\'] = \'Rentals.ca (asking rent)\'\n",
    "\n",
    "bridge_df = bridge_raw[[\'year\', \'zone\', \'bedroom_type\', \'avg_rent\']].copy()\n",
    "bridge_df.columns = [\'year\', \'zone\', \'bedroom_type\', \'value\']\n",
    "bridge_df = bridge_df[bridge_df[\'bedroom_type\'].isin(BEDROOM_TYPES)]\n",
    "\n",
    "print(\'2026 bridge data:\')\n",
    "print(bridge_df)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 7 — Build Master Rent Series"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Combine CMHC (2018-2025) with Rentals.ca (2026)\n",
    "cmhc_cma = rent_cma[[\'year\', \'zone\', \'bedroom_type\', \'value\']].copy()\n",
    "cmhc_cma[\'data_source\'] = \'CMHC RMS\'\n",
    "\n",
    "master = pd.concat([cmhc_cma, bridge_df.assign(data_source=\'Rentals.ca\')], ignore_index=True)\n",
    "master = master.rename(columns={\'value\': \'avg_rent\'})\n",
    "master = master.sort_values([\'bedroom_type\', \'year\']).reset_index(drop=True)\n",
    "\n",
    "# Add CPI deflator for inflation adjustment\n",
    "master = master.merge(cpi_annual[[\'year\', \'cpi_deflator\']], on=\'year\', how=\'left\')\n",
    "master[\'avg_rent_real\'] = (master[\'avg_rent\'] * master[\'cpi_deflator\']).round(0)\n",
    "\n",
    "# Save\n",
    "master.to_csv(\'data/processed/master_rent_series.csv\', index=False)\n",
    "\n",
    "print(\'Master rent series (Toronto CMA level):\')\n",
    "print(master.pivot_table(values=\'avg_rent\', index=\'year\', columns=\'bedroom_type\').round(0).to_string())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 8 — Affordability Index\n", "Formula: (avg monthly rent / median monthly income) × 100 = % of income spent on rent\n", "30% = industry threshold for \'unaffordable\'"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "afford = master.merge(income_df[[\'year\', \'median_income\', \'monthly_income\', \'income_source\']], on=\'year\', how=\'left\')\n",
    "afford[\'rent_burden_pct\'] = (afford[\'avg_rent\'] / afford[\'monthly_income\'] * 100).round(1)\n",
    "afford[\'rent_burden_pct_real\'] = (afford[\'avg_rent_real\'] / afford[\'monthly_income\'] * 100).round(1)\n",
    "afford[\'is_unaffordable\'] = afford[\'rent_burden_pct\'] > 30\n",
    "\n",
    "afford.to_csv(\'data/processed/affordability_index.csv\', index=False)\n",
    "\n",
    "print(\'RENT BURDEN % (monthly rent as % of monthly income):\')\n",
    "pivot = afford.pivot_table(values=\'rent_burden_pct\', index=\'year\', columns=\'bedroom_type\').round(1)\n",
    "print(pivot.to_string())\n",
    "print(\'\\nNote: values above 30% = unaffordable by housing industry standard\')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## CELL 9 — Peak-to-Now Recovery Gap"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "results = []\n",
    "for btype in BEDROOM_TYPES:\n",
    "    sub = afford[afford[\'bedroom_type\'] == btype].sort_values(\'year\')\n",
    "    if sub.empty: continue\n",
    "    \n",
    "    r2019 = sub.loc[sub[\'year\'] == 2019, \'avg_rent\'].values\n",
    "    peak_row = sub.loc[sub[\'avg_rent\'].idxmax()]\n",
    "    curr_row = sub.iloc[-1]\n",
    "    a2019 = sub.loc[sub[\'year\'] == 2019, \'rent_burden_pct\'].values\n",
    "    \n",
    "    if not len(r2019) or not len(a2019): continue\n",
    "    \n",
    "    # How much more rent needs to fall to restore 2019 affordability at 2026 income\n",
    "    inc_2026 = income_df.loc[income_df[\'year\'] == 2026, \'monthly_income\'].values[0]\n",
    "    target_rent = (a2019[0] / 100) * inc_2026\n",
    "    gap = curr_row[\'avg_rent\'] - target_rent\n",
    "    \n",
    "    # Years to close gap at current decline rate\n",
    "    recent = sub[sub[\'year\'].isin([2024, 2025, 2026])].sort_values(\'year\')\n",
    "    ann_decline = recent[\'avg_rent\'].diff().mean()\n",
    "    yrs = round(gap / abs(ann_decline), 1) if ann_decline < 0 and gap > 0 else \'N/A\'\n",
    "    \n",
    "    results.append({\n",
    "        \'Bedroom Type\': btype,\n",
    "        \'2019 Rent\': int(r2019[0]),\n",
    "        \'Peak Rent\': int(peak_row[\'avg_rent\']),\n",
    "        \'Peak Year\': int(peak_row[\'year\']),\n",
    "        \'Current Rent (2026)\': int(curr_row[\'avg_rent\']),\n",
    "        \'Rise 2019→Peak %\': round((peak_row[\'avg_rent\'] - r2019[0]) / r2019[0] * 100, 1),\n",
    "        \'Fall from Peak %\': round((curr_row[\'avg_rent\'] - peak_row[\'avg_rent\']) / peak_row[\'avg_rent\'] * 100, 1),\n",
    "        \'2019 Burden %\': a2019[0],\n",
    "        \'2026 Burden %\': curr_row[\'rent_burden_pct\'],\n",
    "        \'Gap vs 2019 (pp)\': round(curr_row[\'rent_burden_pct\'] - a2019[0], 1),\n",
    "        \'$ Need to Fall More\': round(gap, 0),\n",
    "        \'Est. Years to Recover\': yrs,\n",
    "    })\n",
    "\n",
    "recovery_df = pd.DataFrame(results)\n",
    "recovery_df.to_csv(\'data/processed/recovery_gap.csv\', index=False)\n",
    "\n",
    "print(\'RECOVERY GAP ANALYSIS\')\n",
    "print(\'=\' * 60)\n",
    "for _, r in recovery_df.iterrows():\n",
